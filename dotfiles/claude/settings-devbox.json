{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "defaultMode": "bypassPermissions",
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/terminal-title stopped"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/terminal-title working"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/terminal-title stopped"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/terminal-title"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/terminal-title waiting"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/terminal-title waiting && printf '\\a'"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "aviator-plugins": {
      "source": {
        "source": "github",
        "repo": "aviator-co/agent-plugins"
      }
    }
  },
  "enabledPlugins": {
    "av-cli@aviator-plugins": true
  }
}
